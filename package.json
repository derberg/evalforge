{
  "name": "eval-bench",
  "version": "0.11.7",
  "description": "Benchmark Claude Code plugins by A/B comparing plugin versions with LLM-judged evaluation prompts.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "eval-bench": "dist/cli/index.js",
    "eb": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "prepublishOnly": "npm run build",
    "publish:dry": "npm publish --dry-run"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.4.0",
    "tmp": "^0.2.3",
    "undici": "^8.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.14",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "eslint": "^9.9.0",
    "globals": "^15.15.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/derberg/eval-bench.git"
  },
  "bugs": {
    "url": "https://github.com/derberg/eval-bench/issues"
  },
  "homepage": "https://github.com/derberg/eval-bench#readme",
  "keywords": [
    "claude",
    "claude-code",
    "llm",
    "eval",
    "benchmark",
    "plugin",
    "skills",
    "mcp"
  ]
}
